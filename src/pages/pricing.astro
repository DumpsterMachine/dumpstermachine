---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pricing | Dumpster Machine">
	<main class="bg-slate-50 py-24 min-h-[70vh]">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h1 class="text-5xl font-black uppercase tracking-tight mb-6 text-slate-900">Transparent Pricing</h1>
			<p class="text-xl text-slate-600 font-medium leading-relaxed mb-12">
				We don't play games with hidden fees or surprise environmental charges. Because landfill fees vary drastically by city, our pricing is specifically tailored to your local market. 
			</p>
			
			<div class="bg-white p-12 shadow-[8px_8px_0px_rgba(22,163,74,1)] border-4 border-slate-900 rounded-sm">
				<h2 class="text-3xl font-black uppercase mb-4 text-slate-900">Get Your Local Flat-Rate</h2>
				<p class="text-lg text-slate-600 font-medium mb-8">
					Select your city and dumpster size to instantly see the flat-rate price for your area, including generous weight allowances and rental days.
				</p>
				<a href="/quote" class="bg-green-600 text-slate-900 font-black text-2xl px-12 py-6 rounded-sm shadow-[6px_6px_0px_rgba(0,0,0,0.5)] hover:shadow-[2px_2px_0px_rgba(0,0,0,0.5)] hover:translate-y-[4px] hover:translate-x-[4px] transition-all uppercase tracking-wider inline-block">
					Find My City & Price
				</a>
			</div>
		</div>
	</main>
</Layout>
