---
import Layout from '../../layouts/Layout.astro';
import cities from '../../data/cities.json';

export function getStaticPaths() {
  return cities.map(city => ({
    params: { city: city.name },
    props: { city },
  }));
}

const { city } = Astro.props;
---

<Layout title={`Dumpster Rental in ${city.display} | Dumpster Machine`}>
	<main>
		<!-- City Hero Section -->
		<section class="bg-slate-900 text-white relative overflow-hidden py-24 md:py-36">
			<div class="absolute inset-0 opacity-100">
				<div class="w-full h-full bg-[url('/hero-bg.jpg')] bg-cover bg-center"></div>
			</div>
			<div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 via-slate-900/40 to-transparent"></div>
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
				<h1 class="text-5xl md:text-7xl font-black mb-6 leading-tight tracking-tighter uppercase text-white">
					Dumpster Rental in <br class="hidden md:block"/>
					<span class="text-green-500">{city.display}</span>
				</h1>
				<p class="text-xl md:text-2xl mb-12 max-w-3xl mx-auto text-slate-300 font-medium">
					Tackling a big project in {city.display}? Let us handle the waste. Kick back and relax—<strong class="text-white bg-green-600/30 px-2 py-1 rounded border border-green-500/50">you don't even need to be home for delivery!</strong>
				</p>
				<div class="flex flex-col sm:flex-row justify-center gap-4">
					<a href="/quote" class="bg-green-600 text-slate-900 font-black text-xl px-10 py-5 rounded-sm shadow-[6px_6px_0px_rgba(0,0,0,0.5)] hover:shadow-[2px_2px_0px_rgba(0,0,0,0.5)] hover:translate-y-[4px] hover:translate-x-[4px] transition-all uppercase tracking-wider block sm:inline-block">
						See Flat-Rate Pricing
					</a>
				</div>
			</div>
		</section>

		<!-- Guarantees Section -->
		<section class="py-20 bg-slate-50">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="text-center mb-16">
					<h2 class="text-4xl font-black uppercase text-slate-900 tracking-tight">The Dumpster Machine Difference</h2>
				</div>
				
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<div class="bg-white p-10 shadow-[8px_8px_0px_rgba(22,163,74,1)] border-4 border-slate-900 rounded-sm">
						<div class="w-16 h-16 bg-slate-900 text-green-600 rounded-sm flex items-center justify-center text-3xl font-black mb-6">1</div>
						<h3 class="text-2xl font-black uppercase text-slate-900 mb-4">The $50 On-Time Guarantee</h3>
						<p class="text-slate-600 font-medium">If we don't deliver on the day we agreed to, we refund you $50.</p>
					</div>
					<div class="bg-white p-10 shadow-[8px_8px_0px_rgba(22,163,74,1)] border-4 border-slate-900 rounded-sm">
						<div class="w-16 h-16 bg-slate-900 text-green-600 rounded-sm flex items-center justify-center text-3xl font-black mb-6">2</div>
						<h3 class="text-2xl font-black uppercase text-slate-900 mb-4">Transparent Pricing</h3>
						<p class="text-slate-600 font-medium">Flat-rate pricing with a generous weight allowance included.</p>
					</div>
					<div class="bg-white p-10 shadow-[8px_8px_0px_rgba(22,163,74,1)] border-4 border-slate-900 rounded-sm">
						<div class="w-16 h-16 bg-slate-900 text-green-600 rounded-sm flex items-center justify-center text-3xl font-black mb-6">3</div>
						<h3 class="text-2xl font-black uppercase text-slate-900 mb-4">No Need To Be Home</h3>
						<p class="text-slate-600 font-medium">We deliver so you can start right when you need to.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Trust Section specific to city -->
		<section class="py-20 bg-slate-50">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
				<h2 class="text-4xl font-black uppercase text-slate-900 tracking-tight mb-6">The Best Independent Haulers in {city.display}</h2>
				<p class="text-xl text-slate-600 font-medium max-w-3xl mx-auto mb-12">
					We partner exclusively with top-tier, fully-insured local crews in {city.display}.
				</p>
                <div class="inline-block bg-white p-8 shadow-[8px_8px_0px_rgba(22,163,74,1)] border-4 border-slate-900 rounded-sm">
                    <p class="text-2xl font-black uppercase text-slate-900 mb-2">Ready to book?</p>
                    <p class="text-3xl text-green-600 font-black">{city.phone}</p>
                </div>
			</div>
		</section>
	</main>
</Layout>
