---
import Layout from '../../../layouts/Layout.astro';
import cities from '../../../data/cities.json';

export function getStaticPaths() {
  return cities.map(city => ({
    params: { state: city.state.toLowerCase(), city: city.name },
    props: { city },
  }));
}

const { city } = Astro.props;
---

<Layout title={`Dumpster Rental in ${city.display} | Dumpster Machine`}>
	<main>
		<!-- City Hero Section -->
		<section class="bg-slate-900 text-white relative overflow-hidden py-24 md:py-36">
			<div class="absolute inset-0 opacity-100">
				<div class="w-full h-full bg-[url('/hero-bg.jpg')] bg-cover bg-center"></div>
			</div>
			<div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 via-slate-900/40 to-transparent"></div>
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
				<h1 class="text-5xl md:text-7xl font-black mb-6 leading-tight tracking-tighter uppercase text-white">
					Dumpster Rental in {city.display}
				</h1>
				<p class="text-xl md:text-2xl mb-12 max-w-3xl mx-auto text-slate-300 font-medium">
					Tackling a big project in {city.display}? Let us handle the waste. Kick back and relax—you don't even need to be home for delivery!
				</p>
				<div class="flex flex-col sm:flex-row justify-center gap-4">
					<a href="/quote" class="bg-green-600 text-slate-900 font-black text-xl px-10 py-5 rounded-sm shadow-[6px_6px_0px_rgba(0,0,0,0.5)] hover:shadow-[2px_2px_0px_rgba(0,0,0,0.5)] hover:translate-y-[4px] hover:translate-x-[4px] transition-all uppercase tracking-wider block sm:inline-block">
						See Flat-Rate Pricing
					</a>
				</div>
			</div>
		</section>

		<!-- Size Guide -->
		<section class="py-20">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<h2 class="text-4xl font-black uppercase text-slate-900 mb-12 text-center">Dumpster Size Guide</h2>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<div class="bg-white p-8 border-2 border-slate-900 shadow-md">
						<h3 class="text-xl font-black uppercase mb-2">10-Yard Bin</h3>
						<p class="text-slate-600">Ideal for single-room cleanouts or small bathroom renovations.</p>
					</div>
					<div class="bg-white p-8 border-2 border-slate-900 shadow-md">
						<h3 class="text-xl font-black uppercase mb-2">20-Yard Bin</h3>
						<p class="text-slate-600">The perfect all-rounder for general junk removal or medium home projects.</p>
					</div>
					<div class="bg-white p-8 border-2 border-slate-900 shadow-md">
						<h3 class="text-xl font-black uppercase mb-2">30-Yard Bin</h3>
						<p class="text-slate-600">Built for full home renovations and large-scale construction debris.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Process Timeline -->
		<section class="py-20 bg-slate-900 text-white">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<h2 class="text-4xl font-black uppercase mb-12 text-center text-green-500">How It Works</h2>
				<div class="grid grid-cols-1 md:grid-cols-4 gap-8 text-center">
					<div><div class="text-4xl font-black mb-2">1</div><p class="font-bold">Book Online</p></div>
					<div><div class="text-4xl font-black mb-2">2</div><p class="font-bold">We Prepare Delivery</p></div>
					<div><div class="text-4xl font-black mb-2">3</div><p class="font-bold">You Load It Up</p></div>
					<div><div class="text-4xl font-black mb-2">4</div><p class="font-bold">We Haul It Away</p></div>
				</div>
			</div>
		</section>

		<!-- Prohibited Items & FAQ -->
        <section class="py-20 bg-slate-50">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid md:grid-cols-2 gap-12">
					<div class="bg-white p-10 border-l-4 border-red-600 shadow-lg">
						<h3 class="text-2xl font-black uppercase text-red-600 mb-4">Prohibited Items</h3>
						<p class="text-slate-600 mb-4">To avoid extra fees, review local restricted items (tires, batteries, etc.) for {city.display}. Never assume an item is safe—call us if you're unsure.</p>
						<a href="tel:8885550100" class="text-green-600 font-black">Call to Verify: 888-555-0100</a>
					</div>
					<div class="bg-white p-10 border-l-4 border-green-600 shadow-lg">
						<h3 class="text-2xl font-black uppercase text-green-600 mb-4">{city.display} FAQs</h3>
						<p class="text-slate-600 font-bold mb-2">Do I need a permit in {city.display}?</p>
						<p class="text-slate-500 mb-4 text-sm">Most street placements require local authorization. Check city hall guidelines.</p>
						<p class="text-slate-600 font-bold mb-2">Weight allowances in {city.display}?</p>
						<p class="text-slate-500 text-sm">Every rental includes a specific weight allowance for local landfill rates.</p>
					</div>
				</div>
            </div>
        </section>
	</main>
</Layout>
