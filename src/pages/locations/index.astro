---

<Layout title="City Directory | Dumpster Machine">
	<main class="py-20 bg-slate-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<h1 class="text-4xl font-black uppercase text-slate-900 mb-12 text-center">Service Locations</h1>
			<div class="grid grid-cols-2 md:grid-cols-4 gap-6">
				{cities.map(city => (
					<a href={`/locations/${city.name}`} class="bg-white p-6 shadow-md border border-slate-200 rounded-sm hover:shadow-lg transition-shadow hover:border-green-500 hover:text-green-600 font-bold uppercase text-center block">
						{city.display}
					</a>
				))}
			</div>
		</div>
	</main>
</Layout>
