---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thank You | Dumpster Machine">
	<main class="bg-slate-50 py-24 min-h-[70vh] flex items-center">
		<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			
			<div class="bg-white p-12 shadow-[8px_8px_0px_rgba(22,163,74,1)] border-4 border-slate-900 rounded-sm">
				<div class="flex justify-center mb-8">
					<img src="/logo.png" alt="Dumpster Machine" class="h-32 md:h-48 w-auto object-contain" />
				</div>
				
				<h1 class="text-5xl font-black uppercase text-slate-900 tracking-tight mb-6">You're All Set.</h1>
				
				<p class="text-xl text-slate-600 font-medium mb-8 leading-relaxed">
					We've received your details. We'll crunch the numbers and reach out to you shortly with a transparent, flat-rate price. No hidden fees. No surprises.
				</p>

				<a href="/" class="bg-slate-900 text-white font-black text-xl px-10 py-5 rounded-sm shadow-[4px_4px_0px_rgba(22,163,74,1)] hover:shadow-[2px_2px_0px_rgba(22,163,74,1)] hover:translate-y-[2px] hover:translate-x-[2px] transition-all uppercase tracking-wider inline-block">
					Back to Homepage
				</a>
			</div>

		</div>
	</main>
</Layout>
