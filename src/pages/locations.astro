---
import Layout from '../../layouts/Layout.astro';
import cities from './cities.json';

// Group cities by state
const states = {};
cities.forEach(city => {
    // Add state field if missing during this transition, using the display string
    const stateName = city.state || city.display.split(', ')[1] || 'Other';
    if (!states[stateName]) states[stateName] = [];
    states[stateName].push(city);
});

const sortedStates = Object.keys(states).sort();
---

<Layout title="City Directory | Dumpster Machine">
	<main class="py-20 bg-slate-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<h1 class="text-4xl font-black uppercase text-slate-900 mb-12 text-center">Service Locations</h1>
            
            {sortedStates.map(state => (
                <div class="mb-12">
                    <h2 class="text-2xl font-black uppercase text-green-600 mb-6 border-b-2 border-green-600 pb-2">{state}</h2>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                        {states[state].map(city => (
                            <a href={`/locations/${state.toLowerCase()}/${city.name}`} class="bg-white p-6 shadow-md border border-slate-200 rounded-sm hover:shadow-lg transition-shadow hover:border-green-500 hover:text-green-600 font-bold uppercase text-center block">
                                {city.display.split(',')[0]}
                            </a>
                        ))}
                    </div>
                </div>
            ))}
		</div>
	</main>
</Layout>
